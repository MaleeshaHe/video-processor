# Dependencies (installed fresh inside Docker)
node_modules/

# TypeScript output (compiled inside Docker)
dist/

# Temp and upload files
temp/
logs/

# Development files
.env
.env.*
!.env.example

# Video files (never include in build context)
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.mp3

# IDE and OS files
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation (not needed at runtime)
README.md

# Test files
*.test.ts
*.spec.ts
